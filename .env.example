# Скопируй в .env и заполни своими значениями
# .env имеет приоритет над config.yaml

# ─── GigaChat (Сбер) ───────────────────────────────────────
# Получить ключ: https://developers.sber.ru/studio
# GIGACHAT_CREDENTIALS=ВАШ_АВТОРИЗАЦИОННЫЙ_КЛЮЧ

# ─── OpenAI / OpenAI-совместимые ───────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Примеры других провайдеров (OpenAI-совместимые):
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_BASE_URL=http://localhost:11434/v1  # Ollama

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Поиск ─────────────────────────────────────────────────
# TAVILY_API_KEY=tvly-...

# ─── LangSmith (опционально, для трейсинга) ────────────────
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=deep-research-agent
